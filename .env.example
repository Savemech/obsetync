# Copy to .env and edit if needed.
# `just` auto-loads .env via `set dotenv-load`.

# ---------------------------------------------------------------------------
# Only needed for `just ship` — a personal deploy helper that rsync's the
# compiled binary to a remote host and copies plugin files to a local vault.
# Public users building + running locally can ignore all three.
# ---------------------------------------------------------------------------

# SSH target of the remote host that will run sync-server (e.g. root@myvps).
OBSETYNC_SERVER=

# Directory on the remote where `sync-server` will be placed.
OBSETYNC_DEST=/opt/obsetync

# Full path to your local Obsidian vault's plugin directory.
# Example: /home/you/Documents/ObsidianVault/.obsidian/plugins/obsetync
OBSETYNC_VAULT=
