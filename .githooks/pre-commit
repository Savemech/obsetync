#!/bin/sh
# Local identifier guard — blocks commits that introduce any string from
# .secrets-denylist (which is gitignored, so your real names live only on
# this machine and never get committed by definition).
#
# Activate once per clone:  git config core.hooksPath .githooks
# Bypass in a pinch:         git commit --no-verify
root="$(git rev-parse --show-toplevel)"
denylist="$root/.secrets-denylist"
[ -f "$denylist" ] || exit 0   # no list → nothing to enforce (fresh clones)

added="$(git diff --cached --no-color --diff-filter=ACM | grep '^+' | grep -v '^+++')"
[ -n "$added" ] || exit 0

hit=0
while IFS= read -r pat; do
    case "$pat" in ''|\#*) continue ;; esac
    if printf '%s\n' "$added" | grep -iEq -- "$pat"; then
        echo "pre-commit BLOCK: staged change introduces denylisted string  /$pat/" >&2
        hit=1
    fi
done < "$denylist"

if [ "$hit" -ne 0 ]; then
    echo "" >&2
    echo "Real deployment identifiers must not be committed (see .secrets-denylist)." >&2
    echo "Fix the lines above, or bypass deliberately with: git commit --no-verify" >&2
    exit 1
fi
exit 0
